# ── Copy this to .env and fill in your values ──────────────────
# Generate a secret key with: python -c "import secrets; print(secrets.token_urlsafe(60))"

DJANGO_SECRET_KEY=REPLACE_WITH_YOUR_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=YOUR_SERVER_IP,inixr.com,www.inixr.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://inixr.com,https://www.inixr.com
